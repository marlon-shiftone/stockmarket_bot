TRADING_MODE=paper
BROKER_PROVIDER=paper                  # paper | alpaca
ALLOW_LIVE_TRADING=false
NW_BANDWIDTH=8.0                      # largura base do envelope de Nadaraya-Watson
NW_MULT=0.75                          # PDF usa 3.0; este valor mais agressivo ajuda a disparar sinais em acoes
MKR_BANDWIDTH=9.0                     # suavizacao do Multi Kernel Regression
REQUIRE_CONFIRMATION=false            # false = 1 candle fora do envelope ja pode sinalizar
REQUIRE_TREND_METER=false            # false = ignora o gate do Trend Meter na entrada
REQUIRE_MKR_ALIGNMENT=true           # mantenha true para ainda exigir alinhamento minimo de tendencia

ALPACA_API_KEY="SUA_KEY"
ALPACA_API_SECRET="SUA_SECRET"
ALPACA_BASE_URL="https://paper-api.alpaca.markets"
ALPACA_ASSET_CLASS="stocks"            # stocks | crypto
ALPACA_BAR_TIMEFRAME="5Min"            # ex: 1Min, 5Min, 15Min, 1Hour
SYMBOL="AAPL"                          # stocks: AAPL | crypto: BTC/USD

API_INGEST_URL="http://127.0.0.1:8000/v1/candles"
ALPACA_DATA_URL="https://data.alpaca.markets/v2/stocks/bars"
POLL_INTERVAL_SECONDS=5
NO_DATA_WARN_EVERY_POLLS=12
UNCHANGED_BAR_WARN_EVERY_POLLS=12

# One-shot validation config (historical data + /v1/backtest/report)
VALIDATION_LOOKBACK_DAYS=7
VALIDATION_OUTPUT_DIR="data/validation"
VALIDATION_REPORT_OUTPUT_DIR="reports/backtests"
VALIDATION_REPORT_PERIOD="day"         # day | week | month
VALIDATION_API_BASE_URL="http://127.0.0.1:8000"
VALIDATION_QTY=1
VALIDATION_INITIAL_CAPITAL=10000
VALIDATION_STOCK_FEED="iex"            # iex (recomendado) | sip

# Optimization config (grid search + optional walk-forward)
OPTIMIZATION_CACHE_DIR="data/cache/alpaca"
OPTIMIZATION_OUTPUT_DIR="data/optimization"
OPT_NW_BANDWIDTHS="8.0,10.0"
OPT_NW_MULTS="1.5,1.0,0.75"
OPT_MKR_BANDWIDTHS="9.0,11.0"
OPT_REQUIRE_CONFIRMATION_VALUES="true,false"
OPT_REQUIRE_TREND_METER_VALUES="true,false"
OPT_REQUIRE_MKR_ALIGNMENT_VALUES="true,false"
OPT_MIN_TRADES=20
OPT_MIN_PROFIT_FACTOR=1.2
OPT_MAX_DRAWDOWN_PCT=5.0
OPT_DRAWDOWN_WEIGHT=1.0
OPT_PROFIT_FACTOR_WEIGHT=0.25
OPT_PROFIT_FACTOR_CAP=5.0
OPT_REFINE_TOP_K=3
OPT_NW_BANDWIDTH_REFINE_STEP=1.0
OPT_NW_MULT_REFINE_STEP=0.25
OPT_MKR_BANDWIDTH_REFINE_STEP=1.0
OPT_WALK_FORWARD=false
OPT_WF_TRAIN_BARS=
OPT_WF_TEST_BARS=
OPT_WF_STEP_BARS=
OPT_WF_ANCHORED=false
