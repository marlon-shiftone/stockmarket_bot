# Balanced preset validated on 2026-03-24 using Alpaca historical bars.
# Window tested: 2026-03-17 to 2026-03-24.
# Best balanced result found: AAPL, 15Min, NW_MULT=0.75,
# REQUIRE_CONFIRMATION=false, REQUIRE_TREND_METER=false, REQUIRE_MKR_ALIGNMENT=true.

TRADING_MODE=paper
BROKER_PROVIDER=alpaca
ALLOW_LIVE_TRADING=false
DEFAULT_ORDER_QTY=1.0
NW_BANDWIDTH=8.0
NW_MULT=0.75
MKR_BANDWIDTH=9.0
REQUIRE_CONFIRMATION=false
REQUIRE_TREND_METER=false
REQUIRE_MKR_ALIGNMENT=true

ALPACA_API_KEY="SUA_KEY"
ALPACA_API_SECRET="SUA_SECRET"
ALPACA_BASE_URL="https://paper-api.alpaca.markets"
ALPACA_ASSET_CLASS="stocks"
ALPACA_BAR_TIMEFRAME="15Min"
SYMBOL="AAPL"

API_INGEST_URL="http://127.0.0.1:8000/v1/candles"
ALPACA_DATA_URL="https://data.alpaca.markets/v2/stocks/bars"
POLL_INTERVAL_SECONDS=5
NO_DATA_WARN_EVERY_POLLS=12
UNCHANGED_BAR_WARN_EVERY_POLLS=12

VALIDATION_LOOKBACK_DAYS=7
VALIDATION_OUTPUT_DIR="data/validation"
VALIDATION_REPORT_OUTPUT_DIR="reports/backtests"
VALIDATION_REPORT_PERIOD="day"
VALIDATION_API_BASE_URL="http://127.0.0.1:8000"
VALIDATION_QTY=1
VALIDATION_INITIAL_CAPITAL=10000
VALIDATION_STOCK_FEED="iex"
